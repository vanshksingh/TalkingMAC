# TalkingMAC — environment configuration
# Copy to .env and fill in your values

# ── AI Backend ──────────────────────────────────────────────
# Choose "ollama" (local) or "gemini" (cloud)
AI_BACKEND=ollama

# LLM interaction mode:
# - chat  = normal assistant replies
# - tools = LangChain-style tool-calling loop
LLM_INTERACTION_MODE=tools
AGENT_MAX_STEPS=4

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Gemini — get key at https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# ── Voice ────────────────────────────────────────────────────
WAKE_WORD=hey mac
# 1 = wake word can interrupt ongoing responses, 0 = only trigger when idle
WAKE_WORD_INTERRUPTION_ENABLED=1

# Wake/barge-in sensitivity tuning
# Higher energy/debounce/threshold values reduce false triggers.
WAKE_CHECK_STEP_SECS=0.4
WAKE_ENERGY_THRESH=0.0015
WAKE_MIN_TRIGGER_INTERVAL_SECS=1.2
WAKE_IDLE_FIRST_TOKEN_MIN=0.74
WAKE_IDLE_SECOND_TOKEN_MIN=0.63
WAKE_TTS_FIRST_TOKEN_MIN=0.86
WAKE_TTS_SECOND_TOKEN_MIN=0.82
WAKE_IDLE_MAX_GAP_TOKENS=3
WAKE_TTS_MAX_GAP_TOKENS=1
WAKE_TTS_PREFIX_TOKEN_LIMIT=1

# STT engine: "google" (internet required) or "whisper" (local)
STT_ENGINE=google

# TTS
TTS_RATE=165
TTS_VOLUME=0.9
# Voice output preset: default | female | male | classic | robot | whisper
TTS_VOICE_TYPE=default
# Optional explicit OS voice name (overrides TTS_VOICE_TYPE)
TTS_VOICE_NAME=
# Backend selection: auto | say | pyttsx3 | spd-say | espeak | espeak-ng
TTS_BACKEND=auto

# ── Tools (used when LLM_INTERACTION_MODE=tools) ────────────
TOOL_REPL_ENABLED=1
TOOL_TERMINAL_ENABLED=1
TOOL_WEB_SEARCH_ENABLED=1
TOOL_TERMINAL_TIMEOUT_SECS=8
TOOL_WEB_SEARCH_MAX_RESULTS=5

# ── UI Startup Mode ──────────────────────────────────────────
# fullscreen | windowed | borderless | floating | fullscreen_borderless
UI_WINDOW_MODE=fullscreen
# Force no-border fullscreen regardless of UI_WINDOW_MODE
UI_FORCE_FULLSCREEN=0
UI_WINDOW_WIDTH=1280
UI_WINDOW_HEIGHT=800

# Auto-sleep face timeout in seconds while idle.
# Set to 0 to disable auto-sleep completely.
IDLE_SLEEP_TIMEOUT_SECS=60
