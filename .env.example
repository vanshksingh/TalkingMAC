# TalkingMAC — environment configuration
# Copy to .env and fill in your values

# ── AI Backend ──────────────────────────────────────────────
# Choose "ollama" (local) or "gemini" (cloud)
AI_BACKEND=ollama

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Gemini — get key at https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# ── Voice ────────────────────────────────────────────────────
WAKE_WORD=hey mac
# 1 = wake word can interrupt ongoing responses, 0 = only trigger when idle
WAKE_WORD_INTERRUPTION_ENABLED=1

# STT engine: "google" (internet required) or "whisper" (local)
STT_ENGINE=google

# TTS
TTS_RATE=165
TTS_VOLUME=0.9
